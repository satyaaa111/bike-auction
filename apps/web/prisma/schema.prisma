generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  BUYER
  ADMIN
}

enum AuctionStatus {
  SCHEDULED
  LIVE
  CLOSED
  CANCELLED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(BUYER)
  createdAt    DateTime @default(now())

  bids          Bid[]
  auctions      Motorcycle[]          @relation("CreatedByAdmin")
  auditLogs     AuditLog[]
  registrations AuctionRegistration[]
}

model Motorcycle {
  id             String   @id @default(cuid())
  make           String
  model          String
  year           Int
  mileageKm      Int
  condition      String
  imageUrls      String[]
  createdByAdmin User     @relation("CreatedByAdmin", fields: [createdByAdminId], references: [id])
  createdByAdminId String
  createdAt      DateTime @default(now())

  auction Auction?
}

model Auction {
  id                  String        @id @default(cuid())
  motorcycle          Motorcycle    @relation(fields: [motorcycleId], references: [id], onDelete: Cascade)
  motorcycleId        String        @unique
  title               String
  description         String
  regStartTime        DateTime
  regEndTime          DateTime
  startTime           DateTime
  endTime             DateTime
  startingBidPaise    BigInt
  reservePricePaise   BigInt?
  currentHighestBid   Bid?          @relation("CurrentHighestBid", fields: [currentHighestBidId], references: [id], onDelete: SetNull)
  currentHighestBidId String?       @unique
  status              AuctionStatus @default(SCHEDULED)
  version             Int           @default(0)
  createdAt           DateTime      @default(now())

  bids          Bid[]                 @relation("AuctionBids")
  registrations AuctionRegistration[]

  @@index([status, startTime])
  @@index([status, endTime])
}

model Bid {
  id         String   @id @default(cuid())
  auction    Auction  @relation("AuctionBids", fields: [auctionId], references: [id], onDelete: Cascade)
  auctionId  String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  amountPaise BigInt
  createdAt  DateTime @default(now())

  // Back-relation for Auction.currentHighestBid
  highestForAuction Auction? @relation("CurrentHighestBid")

  @@index([auctionId, amountPaise])
}

model AuctionRegistration {
  id        String   @id @default(cuid())
  auctionId String
  userId    String
  createdAt DateTime @default(now())

  auction   Auction  @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([auctionId, userId])
  @@index([auctionId])
  @@index([userId])
}

model AuditLog {
  id         String   @id @default(cuid())
  actor      User?    @relation(fields: [actorId], references: [id])
  actorId    String?
  action     String
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
}
